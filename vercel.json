{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/next"
        },
        {
            "src": "api/main.py",
            "use": "@vercel/python",
            "config": {
                "maxDuration": 300
            }
        }
    ],
    "routes": [
        {
            "src": "/api/py/(users|categories|albums)$",
            "dest": "/api/main.py",
            "headers": {
                "Cache-Control": "public, s-maxage=600, stale-while-revalidate=3600"
            }
        },
        {
            "src": "/api/py/episodes(\\?.*)?$",
            "dest": "/api/main.py",
            "headers": {
                "Cache-Control": "public, s-maxage=600, stale-while-revalidate=3600"
            }
        },
        {
            "src": "/api/py/image-proxy/(.*)",
            "dest": "/api/main.py",
            "headers": {
                "Cache-Control": "public, s-maxage=86400, stale-while-revalidate=604800"
            }
        },
        {
            "src": "/api/(.*)",
            "dest": "/api/main.py"
        }
    ],
    "crons": [
        {
            "path": "/api/py/sync",
            "schedule": "0 * * * *"
        }
    ]
}
